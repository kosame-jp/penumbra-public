# Local/manual backups. These are useful while iterating, but should not
# be published as source artifacts or deployed to Vercel.
.local-backups/
*.bak
**/*_[0-9][0-9][0-9][0-9][0-9][0-9]_*

# Cloud forecast generations are operational artifacts. Commit the active
# manifest and force-add the frame files it references; keep stale aliases and
# retained generations out of the source history.
public/data/cloud-atlas.forecast.backups/
public/data/cloud-atlas.forecast/f*.json
public/data/cloud-atlas.forecast/[0-9]*T*-f*.json

# Local data caches (downloaded geo/audio assets)
data/cache/
data/raw/

# Local source bundle backups
penumbra-source-kit.zip
