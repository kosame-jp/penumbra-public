{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://penumbra.app/schemas/cloud-atlas-manifest.schema.json",
  "title": "PENUMBRA Visual Cloud Atlas Forecast Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generatedAtUtc",
    "interpolation",
    "source",
    "frames"
  ],
  "properties": {
    "version": { "type": "string" },
    "generatedAtUtc": { "type": "string", "format": "date-time" },
    "activeCycleUtc": { "type": "string", "format": "date-time" },
    "transitionDurationMinutes": { "type": "number", "minimum": 0, "maximum": 180 },
    "interpolation": {
      "type": "string",
      "enum": ["linear-time"]
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "provenance"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["noaa-gfs", "open-meteo", "provisional-fixture"]
        },
        "model": { "type": "string" },
        "cycleUtc": { "type": "string", "format": "date-time" },
        "provenance": { "type": "string" }
      }
    },
    "frames": {
      "type": "array",
      "minItems": 1,
      "maxItems": 24,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url", "validAtUtc"],
        "properties": {
          "url": { "type": "string", "minLength": 1 },
          "validAtUtc": { "type": "string", "format": "date-time" },
          "cycleUtc": { "type": "string", "format": "date-time" },
          "forecastHour": { "type": "integer", "minimum": 0 },
          "label": { "type": "string" }
        }
      }
    }
  }
}
