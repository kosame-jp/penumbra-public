{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://penumbra.app/schemas/cloud-atlas.schema.json",
  "title": "PENUMBRA Visual Cloud Atlas",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generatedAtUtc",
    "validAtUtc",
    "resolutionDeg",
    "width",
    "height",
    "latitudeStartDeg",
    "longitudeStartDeg",
    "valuesEncoding",
    "source",
    "values"
  ],
  "properties": {
    "version": { "type": "string" },
    "generatedAtUtc": { "type": "string", "format": "date-time" },
    "validAtUtc": { "type": "string", "format": "date-time" },
    "resolutionDeg": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
    "width": { "type": "integer", "minimum": 1, "maximum": 1440 },
    "height": { "type": "integer", "minimum": 1, "maximum": 721 },
    "latitudeStartDeg": { "type": "number", "minimum": -90, "maximum": 90 },
    "longitudeStartDeg": { "type": "number", "minimum": -180, "maximum": 180 },
    "valuesEncoding": {
      "type": "string",
      "enum": ["uint8-cloud-cover-pct"]
    },
    "opticalDensityValuesEncoding": {
      "type": "string",
      "enum": ["uint8-cloud-water-density-proxy-pct"]
    },
    "precipitationValuesEncoding": {
      "type": "string",
      "enum": ["uint8-precipitation-activity-pct"]
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "provenance"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["noaa-gfs", "open-meteo", "provisional-fixture"]
        },
        "model": { "type": "string" },
        "cycleUtc": { "type": "string", "format": "date-time" },
        "forecastHour": { "type": "integer", "minimum": 0 },
        "provenance": { "type": "string" }
      }
    },
    "values": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "integer", "minimum": 0, "maximum": 100 }
    },
    "opticalDensityValues": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "integer", "minimum": 0, "maximum": 100 }
    },
    "precipitationValues": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "integer", "minimum": 0, "maximum": 100 }
    }
  }
}
